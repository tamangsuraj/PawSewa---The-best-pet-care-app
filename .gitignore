# =========================
# Root / repo-local tooling
# =========================
.cursor/

# =========================
# Node.js (monorepo)
# =========================
**/node_modules/
**/.pnp
**/.pnp.js

# Logs / debug
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*
**/*.log

# Test / coverage
**/coverage/
**/.nyc_output/

# Build outputs
**/dist/
**/build/

# Caches
**/.cache/
**/.eslintcache
**/*.tsbuildinfo
**/.turbo/
**/.parcel-cache/
**/.vite/

# Next.js / Vercel
**/.next/
**/out/
**/.vercel/

# =========================
# Environment / secrets
# =========================
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# =========================
# Flutter / Dart (monorepo)
# =========================
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub/
**/.pub-cache/
**/build/

# Android
**/android/.gradle/
**/android/app/build/
**/android/.cxx/
**/android/local.properties
**/android/key.properties
**/*.keystore
**/*.jks

# iOS / macOS
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/App.framework
**/ios/Flutter/engine/*
**/ios/Runner/GeneratedPluginRegistrant.*
**/macos/Pods/
**/macos/Flutter/ephemeral/

# =========================
# IDEs / editors
# =========================
**/.idea/
**/.vscode/
**/*.iml
**/*.swp
**/*.swo
**/*~

# =========================
# OS cruft
# =========================
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# Windows reserved device-name files (should not exist in repo)
nul
