# Admin (Next.js) environment variables.
# NOTE: This app never connects to MongoDB directly. It calls the backend API, which connects to MongoDB Atlas.

# REST base URL (must include /api/v1). Local backend default port is 3000.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Optional: Socket.io origin without path (defaults from NEXT_PUBLIC_API_URL host, else localhost:3000).
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
