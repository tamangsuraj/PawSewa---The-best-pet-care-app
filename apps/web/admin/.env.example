# Admin (Next.js) environment variables.
# NOTE: This app never connects to MongoDB directly. It calls the backend API, which connects to MongoDB Atlas.

# Preferred: public API base (ngrok or deployed). Must include /api/v1. No hardcoded URLs in app source.
# NEXT_PUBLIC_API_URL=https://YOUR-ID.ngrok-free.app/api/v1

# Local dev only (if NEXT_PUBLIC_API_URL is unset). Same shape as above.
NEXT_PUBLIC_DEV_API_BASE_URL=http://127.0.0.1:3000/api/v1

# Optional: Socket.io origin without path (needed when REST is ngrok-proxied via Next rewrites).
# NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:3000

# Production: comma-separated browser origins for CORS (backend ALLOWED_ORIGINS).
