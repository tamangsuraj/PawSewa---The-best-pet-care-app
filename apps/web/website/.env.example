# Website (Next.js) environment variables.
# NOTE: This app never connects to MongoDB directly. It calls the backend API, which connects to MongoDB Atlas.

# REST base URL (must include /api/v1). Same backend as mobile apps and admin.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Shown when someone tries to use an admin account on the customer site (default local admin port).
NEXT_PUBLIC_ADMIN_PANEL_URL=http://localhost:3002
