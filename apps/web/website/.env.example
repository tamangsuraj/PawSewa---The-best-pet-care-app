# Website (Next.js) environment variables.
# NOTE: This app never connects to MongoDB directly. It calls the backend API, which connects to MongoDB Atlas.

# Preferred: ngrok or deployed API (must include /api/v1).
# NEXT_PUBLIC_API_URL=https://YOUR-ID.ngrok-free.app/api/v1

# Local dev if NEXT_PUBLIC_API_URL is unset:
NEXT_PUBLIC_DEV_API_BASE_URL=http://127.0.0.1:3000/api/v1

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Admin panel link when a user signs in with an admin account (no hardcoded URL in source).
NEXT_PUBLIC_ADMIN_PANEL_URL=http://127.0.0.1:3002
NEXT_PUBLIC_DEV_ADMIN_PANEL_URL=http://127.0.0.1:3002
