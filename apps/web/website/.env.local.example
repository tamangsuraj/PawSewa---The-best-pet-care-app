# Same backend as admin + mobile (…/api/v1). Backend uses MongoDB Atlas Pawsewa-Cluster.
# Use an ngrok origin (or your deployed backend URL). Do not use local MongoDB.
# NEXT_PUBLIC_API_URL=https://your-ngrok-id.ngrok-free.app/api/v1

# Local dev when NEXT_PUBLIC_API_URL is unset (also used as default in code):
NEXT_PUBLIC_DEV_API_BASE_URL=http://127.0.0.1:3000/api/v1
# When using ngrok for REST, sockets should hit local Node unless you set a public socket URL:
# NEXT_PUBLIC_DEV_SOCKET_URL=http://127.0.0.1:3000

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
