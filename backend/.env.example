PORT=3000
NODE_ENV=development
# MongoDB connection string (cluster/host). A path after the host is optional; the active DB is always DB_NAME below.
# Cluster URI. You may omit the path; the server appends /DB_NAME when missing and always passes dbName to Mongoose.
# Example: mongodb://127.0.0.1:27017/pawsewa_chat  OR  mongodb+srv://user:pass@cluster.mongodb.net/pawsewa_chat
MONGO_URI=your_mongodb_connection_string_here
# Logical database name (passed to Mongoose as dbName). REQUIRED — server will not start if unset.
# All platforms should read/write pawsewa_chat (e.g. pawsewa_chat.pets in Compass).
DB_NAME=pawsewa_chat
# When true, logs each Pet save: [DB_SAVE] <db> pets <_id> (debugging split-brain / missing pets).
# LOG_DB_SAVE=true
# When true, logs database name on every API request (verbose; use only when debugging).
# LOG_DB_EVERY_REQUEST=true
JWT_SECRET=your_jwt_secret_key_here

# MongoDB ObjectId of the User who acts as "Customer Care" for default support chats (must be role admin).
# After `npm run populate:pawsewa` or `node scripts/createAdmin.js`, run `npm run sync:customer-care-admin` to pin the first admin.
# Fixed ID used by master seeder / populate script (creates user if missing):
CUSTOMER_CARE_ADMIN_ID=697ca0d530a61a7f06e3d1ef

# Firebase Cloud Messaging (server push). Paste the full JSON of the service account key as a single line (escape quotes in production or use a secrets manager).
# Download from Firebase Console: Project settings > Service accounts > Generate new private key.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Gmail Configuration for OTP
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Sign-In / OAuth (same Firebase or Cloud project as mobile)
# Use the Web application OAuth 2.0 Client ID as GOOGLE_CLIENT_ID (used by this server + website).
# If unset or left as the placeholder below, authRoutes falls back to PawSewa user_app client IDs from google-services.json.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Optional: allow Android/iOS ID tokens whose aud is the native client ID (comma list overrides all):
# GOOGLE_CLIENT_IDS=web_id.apps.googleusercontent.com,android_id.apps.googleusercontent.com
# Or set individually (merged with GOOGLE_CLIENT_ID if GOOGLE_CLIENT_IDS unset):
# GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
# iOS OAuth client from ios/Runner/GoogleService-Info.plist (CLIENT_ID) if tokens use that aud:
# GOOGLE_CLIENT_ID_IOS=188502859936-h3p7j0sjua98d4j615b58m4lmt0pfj0g.apps.googleusercontent.com
#
# Google Cloud Console → APIs & Services → Credentials:
# - Web client: Authorized JavaScript origins = https://your-domain.com, http://localhost:3001
# - Web client: Authorized redirect URIs (if using auth-code flow) = postmessage, https://your-domain.com, ...
# Firebase Console → Project settings → Your apps: add SHA-1 (debug + release) for Android package com.pawsewa.user_app

# Khalti Payment - Sandbox: https://dev.khalti.com, Production: https://khalti.com
# Get KHALTI_SECRET_KEY from dashboard: test-admin.khalti.com (sandbox) or admin.khalti.com (production)
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key
# Sandbox mode. Production: https://khalti.com/api/v2
KHALTI_BASE_URL=https://dev.khalti.com/api/v2/
# Public URL of this backend (for Khalti return/callback). Use ngrok/tunnel URL when testing (e.g. https://xxx.ngrok-free.app)
BASE_URL=http://localhost:3000
# Optional: User Web success page URL. If set, payment-success redirects here with ?orderId=&pidx=
# Local website (Next) default port 3001:
# PAYMENT_SUCCESS_WEB_URL=http://localhost:3001/checkout/success

# CORS: comma-separated origins in production (e.g. https://yoursite.com,https://admin.yoursite.com). Leave unset for development (allows all).
# ALLOWED_ORIGINS=https://yoursite.com,https://admin.yoursite.com

# Live map: simulated rider/vet jitter + Socket.io `live_map:tick` to admin_room (set false to disable).
# LIVE_MAP_SIMULATION=true
# LIVE_MAP_TICK_MS=5000

# Agora RTC (1:1 voice/video). Token endpoint: GET /api/v1/calls/token — keep certificate server-side only.
AGORA_APP_ID=a6a42b00b6ca4e059dcc1f1866950ad1
AGORA_PRIMARY_CERTIFICATE=3939907179234f08b38d89b383e290b0
# Optional hint for ops/docs (SDK area / routing); not read by token code today.
AGORA_REGION=Singapore

# Universal API URL: All clients (Website, Admin, User App, Vet App) must use the same backend.
# Set BASE_URL (or tunnel URL) and point each app's API config to: <BASE_URL>/api/v1
#
# Quick reference (see README.md "Same backend everywhere"):
# - Local web: NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# - Physical phone: use PC LAN IP or ngrok; keep BASE_URL + Next.js + Flutter in sync
# - DB smoke test: cd backend && node scripts/check-db.js
# - Find which DB holds a pet by name (e.g. Spoidy): node scripts/check-all-dbs.js
