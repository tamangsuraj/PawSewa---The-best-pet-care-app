{
  "name": "pawsewa-backend",
  "version": "1.0.0",
  "description": "PawSewa Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "free-port": "node scripts/free-port.js",
    "dev:fresh": "node scripts/free-port.js && node src/server.js",
    "tunnel": "ngrok http 3000 --pooling-enabled",
    "tunnel:restart": "node scripts/ngrok-restart.js",
    "migrate:production": "node src/scripts/migrateToProduction.js",
    "migrate:core": "node scripts/migrate-to-core.js",
    "sync:production": "node scripts/syncToProduction.js",
    "seed:care": "node scripts/seed-hostels-trainings-centers.js",
    "seed:services": "node src/seeders/serviceSeeder.js",
    "seed:master-user": "node src/seeders/masterUserSeeder.js",
    "seed:resync": "node src/seeders/masterUserSeeder.js && node src/seeders/serviceSeeder.js",
    "seed:products": "node src/seeders/productSeeder.js",
    "seed:data": "node scripts/seed-data.js",
    "seed:core": "node scripts/seed-core.js",
    "sync:customer-care-admin": "node scripts/sync-customer-care-admin-env.js",
    "populate:pawsewa": "node scripts/populate_pawsewa.js",
    "reset:admin-password": "node scripts/reset-super-admin.js",
